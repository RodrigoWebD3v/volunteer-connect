# Aplicações locais
BACKEND_PORT=3000
FRONTEND_PORT=5173

# Supabase remoto
# Preencha com os valores do painel do seu projeto Supabase.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anonima
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-apenas-backend
SUPABASE_LOGOS_BUCKET=logos-ongs

# Supabase no frontend SvelteKit
# Somente chaves publicas devem usar prefixo PUBLIC_.
PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima-publica
PUBLIC_BACKEND_URL=http://localhost:3000

# Redirecionamentos de autenticacao
PUBLIC_AUTH_CONFIRMATION_REDIRECT_URL=http://localhost:5173/auth/confirmacao-email
PUBLIC_AUTH_PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/auth/redefinir-senha

# Banco remoto
# Use a connection string do Supabase quando precisar executar migrations ou scripts SQL diretos.
DATABASE_URL=postgresql://postgres:[SENHA]@db.[PROJECT_REF].supabase.co:5432/postgres
